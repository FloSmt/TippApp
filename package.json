{
  "name": "@tippapp/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "lint": "nx run-many --target=lint",
    "env:dev": "docker compose --env-file ./environments/.env.development up --build",
    "env:test": "docker compose -f docker-compose.test.yaml --env-file ./environments/.env.test up --build",
    "local:backend": "nx run backend:serve",
    "local:backend:mobile-test": "nx run backend:serve --configuration=mobile-test",
    "build:backend": "nx run backend:build",
    "test:backend:e2e": "set NODE_ENV=test && nx run backend-e2e:e2e -- --runInBand",
    "test:backend:e2e:single": "set NODE_ENV=test && nx run backend-e2e:e2e",
    "test:backend:unit": "nx run-many --target=test --projects=libs/backend/* --code-coverage",
    "build:mobile-app": "nx run mobile-app:build",
    "build:mobile-app:mobile-test": "nx run mobile-app:build --configuration=mobile-test",
    "sync:mobile-app": "nx run mobile-app:sync:android",
    "local:mobile-app": "nx run mobile-app:serve --configuration=development",
    "local:mobile-app:mobile-test": "nx run mobile-app:serve --configuration=mobile-test",
    "test:mobile-app:unit": "nx run-many --target=test --projects=libs/frontend/**/* --code-coverage",
    "test:mobile-app:e2e:ui": "set NODE_ENV=test && nx run mobile-app-e2e:e2e --ui",
    "test:mobile-app:e2e": "set NODE_ENV=test && nx run mobile-app-e2e:e2e",
    "test:all:unit": "nx run-many --target=test --code-coverage --verbose"
  },
  "private": true,
